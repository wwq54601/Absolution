[Desktop Entry]
Version=1.0
Type=Application
Name=Guaardvark
Comment=Guaardvark AI Assistant - Launch in app mode
Exec=sh -c 'cd "$(dirname "$0")" && ./start.sh --app-mode'
Path=GUAARDVARK_ROOT
Icon=GUAARDVARK_ROOT/frontend/public/logo.png
Terminal=false
Categories=Utility;Application;Development;
StartupNotify=true
MimeType=
Keywords=AI;Assistant;LLM;Chat;
