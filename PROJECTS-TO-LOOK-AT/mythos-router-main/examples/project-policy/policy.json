{
  "version": 1,
  "block": [
    "contracts/mainnet/**",
    "infra/prod/**"
  ],
  "confirm": [
    "scripts/**",
    ".github/workflows/**",
    "src/payments/**"
  ],
  "limits": {
    "allowDeletes": false,
    "maxActions": 20,
    "maxActionContentBytes": 50000
  },
  "checks": [
    { "name": "typecheck", "command": "npm run -s build" },
    { "name": "test", "command": "npm test" }
  ]
}
